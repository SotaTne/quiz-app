{
  "include": [".react-router/types/**/*", "app/**/*", "workers/**/*", "scripts/**/*", "worker-configuration.d.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "noEmit": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["node", "vite/client"]
  }
}
