{
  "name": "quiz-app-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm db:migrate",
    "dev": "react-router dev --port 3000",
    "build": "react-router build",
    "start": "vite preview --port 3000",
    "deploy": "pnpm build && pnpm db:migrate:remote && wrangler deploy && pnpm cleanup:remote",
    "typegen": "react-router typegen",
    "cf-typegen": "wrangler types",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "cleanup": "node scripts/cleanup-orphaned-attempts.ts",
    "cleanup:remote": "node scripts/cleanup-orphaned-attempts.ts --remote"
  },
  "dependencies": {
    "@mantine/core": "9.4.2",
    "@mantine/hooks": "9.4.2",
    "@quiz/auth": "workspace:*",
    "@quiz/core": "workspace:*",
    "@quiz/db": "workspace:*",
    "isbot": "^5.2.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router": "^8.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@react-router/dev": "^8.3.0",
    "@types/node": "24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.0",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0"
  }
}
